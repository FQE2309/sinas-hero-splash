# Variables de entorno para la aplicación SINAS Landing Page
# Copia este archivo a .env y configura los valores apropiados

# Hash SHA-256 de la contraseña de administración
# Genera el hash de tu contraseña usando: 
# node -e "console.log(require('crypto').createHash('sha256').update('TU_CONTRASEÑA').digest('hex'))"
VITE_ADMIN_PASSWORD_HASH=tu_hash_aqui

# Configuración de desarrollo (opcional)
# VITE_DEV_MODE=true